<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/main.css">
    <title>Organiser Home</title>
</head>
<body>
    <nav class="navbar">
        <div class="container-fluid">
            <span class="navbar-brand">Event Manager</span>
            <a href="/organiser/logout" class="btn btn-secondary btn-sm">Logout</a>
        </div>
    </nav>

    <div class="container">
        <!-- Header -->
        <div class="section">
            <h1>Organiser Home Page</h1>
            <h2><%= site_name %></h2>
            <p class="text-muted"><%= site_description %></p>
        </div>

        <!-- Settings Link & Create Event Button -->
        <div class="section">
            <div class="btn-group-inline">
                <a href="/organiser/settings" class="btn btn-secondary">Site Settings</a>
                <a href="/organiser/event/new" class="btn btn-primary">+ Create New Event</a>
            </div>
        </div>

        <!-- Published Events Section -->
        <div class="section">
            <h2 class="section-title">Published Events</h2>

            <% if (publishedEvents && publishedEvents.length > 0) { %>
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Date</th>
                                <th>Created</th>
                                <th>Published</th>
                                <th>Tickets</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% publishedEvents.forEach(event => { %>
                                <tr>
                                    <td><strong><%= event.title %></strong></td>
                                    <td><%= new Date(event.event_date).toLocaleDateString() %></td>
                                    <td><%= new Date(event.created_at).toLocaleDateString() %></td>
                                    <td><%= new Date(event.published_at).toLocaleDateString() %></td>
                                    <td><small><%= event.ticket_info || '—' %></small></td>
                                    <td>
                                        <div class="btn-group-inline">
                                            <a href="<%= `/attendee/event/${event.event_id}` %>" class="btn btn-sm btn-info" target="_blank">Share</a>
                                            <a href="<%= `/organiser/event/${event.event_id}/guests` %>" class="btn btn-sm btn-secondary">Guests</a>
                                            <form method="POST" action="<%= `/organiser/event/${event.event_id}/delete` %>" style="display: inline;">
                                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this event? This cannot be undone.')">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <p>No published events yet.</p>
                    <p class="text-muted small">Create and publish an event to get started.</p>
                </div>
            <% } %>
        </div>

        <!-- Draft Events Section -->
        <div class="section">
            <h2 class="section-title">Draft Events</h2>

            <% if (draftEvents && draftEvents.length > 0) { %>
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Date</th>
                                <th>Created</th>
                                <th>Tickets</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% draftEvents.forEach(event => { %>
                                <tr>
                                    <td><strong><%= event.title %></strong></td>
                                    <td><%= new Date(event.event_date).toLocaleDateString() %></td>
                                    <td><%= new Date(event.created_at).toLocaleDateString() %></td>
                                    <td><small><%= event.ticket_info || '—' %></small></td>
                                    <td>
                                        <div class="btn-group-inline">
                                            <a href="<%= `/organiser/event/${event.event_id}` %>" class="btn btn-sm btn-secondary">Edit</a>
                                            <form method="POST" action="<%= `/organiser/event/${event.event_id}/publish` %>" style="display: inline;">
                                                <button type="submit" class="btn btn-sm btn-primary">Publish</button>
                                            </form>
                                            <form method="POST" action="<%= `/organiser/event/${event.event_id}/delete` %>" style="display: inline;">
                                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this draft event? This cannot be undone.')">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <p>No draft events yet.</p>
                    <p class="text-muted small">Click "Create New Event" to start building your first event.</p>
                </div>
            <% } %>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
