<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/main.css">
    <title>Organiser Dashboard</title>
    <script src="/main.js" defer></script>
</head>
<body>
    <div class="dashboard-layout">
        <%- include('_sidebar', { activePage: 'home' }) %>

        <main class="dashboard-main">
            <!-- Header -->
            <div class="section">
                <h6 class="page-kicker">Organiser Home Page</h6>
                <h1><%= site_name %></h1>
                <p class="text-muted"><%= site_description %></p>
            </div>

            <!-- Create Event Button -->
            <div class="section">
                <div class="btn-group-inline">
                    <a href="/organiser/event/new" class="btn btn-primary-custom">+ Create New Event</a>
                </div>
            </div>

            <!-- Published Events Section -->
            <div class="section">
                <h2 class="section-title">Published Events</h2>

                <% if (publishedEvents && publishedEvents.length > 0) { %>
                    <div class="event-grid">
                        <% publishedEvents.forEach(event => { %>
                            <%
                                // Parse "full:2, concession:3" into a readable "Full: 2, Concession: 3"
                                const ticketSummary = event.ticket_info
                                    ? event.ticket_info.split(', ').map(pair => {
                                        const [type, qty] = pair.split(':');
                                        return `${type.charAt(0).toUpperCase() + type.slice(1)}: ${qty}`;
                                    }).join(' &middot; ')
                                    : 'No tickets configured';
                            %>
                            <div class="card-ticket-stub">
                                <a href="<%= `/organiser/event/${event.event_id}/guests` %>" class="card-ticket-main">
                                    <h4><%= event.title %></h4>
                                    <p class="text-muted mb-2">
                                        <%= new Date(event.event_date).toLocaleDateString('en-GB', { weekday: 'short', month: 'short', day: 'numeric' }) %>
                                        at <%= new Date(event.event_date).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' }) %>
                                    </p>
                                    <p class="text-muted mb-1" style="font-size: 0.8rem;">
                                        Created <%= new Date(event.created_at).toLocaleDateString('en-GB') %>
                                        &middot; Published <%= new Date(event.published_at).toLocaleDateString('en-GB') %>
                                    </p>
                                    <p class="text-muted mb-2" style="font-size: 0.8rem;"><%- ticketSummary %> tickets</p>
                                    <div>
                                        <span class="badge-stamp published">Published</span>
                                    </div>
                                </a>
                                <div class="card-ticket-stub-section">
                                    <div style="display: flex; flex-direction: row; gap: 0.6rem; width: 100%;">
                                        <a href="<%= `/attendee/event/${event.event_id}` %>" class="btn btn-sm btn-secondary-custom" target="_blank">Share Link</a>
                                        <form method="POST" action="<%= `/organiser/event/${event.event_id}/delete` %>" style="margin: 0; width: 100%;">
                                            <button type="submit" class="btn btn-sm btn-danger-custom w-100" onclick="return confirm('Delete this event? This cannot be undone.')">Delete</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% } else { %>
                    <div class="empty-state">
                        <p>No published events yet.</p>
                        <p class="text-muted small">Create and publish an event to get started.</p>
                    </div>
                <% } %>
            </div>

            <!-- Draft Events Section -->
            <div class="section">
                <h2 class="section-title">Draft Events</h2>

                <% if (draftEvents && draftEvents.length > 0) { %>
                    <div class="event-grid">
                        <% draftEvents.forEach(event => { %>
                            <%
                                const draftTicketSummary = event.ticket_info
                                    ? event.ticket_info.split(', ').map(pair => {
                                        const [type, qty] = pair.split(':');
                                        return `${type.charAt(0).toUpperCase() + type.slice(1)}: ${qty}`;
                                    }).join(' &middot; ')
                                    : 'No tickets configured';
                            %>
                            <div class="card-ticket-stub">
                                <a href="<%= `/organiser/event/${event.event_id}` %>" class="card-ticket-main">
                                    <h4><%= event.title %></h4>
                                    <p class="text-muted mb-2">
                                        <%= new Date(event.event_date).toLocaleDateString('en-GB', { weekday: 'short', month: 'short', day: 'numeric' }) %>
                                        at <%= new Date(event.event_date).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' }) %>
                                    </p>
                                    <p class="text-muted mb-1" style="font-size: 0.8rem;">
                                        Created <%= new Date(event.created_at).toLocaleDateString('en-GB') %>
                                    </p>
                                    <p class="text-muted mb-2" style="font-size: 0.8rem;"><%- draftTicketSummary %> tickets</p>
                                    <div>
                                        <span class="badge-stamp draft">Draft</span>
                                    </div>
                                </a>
                                <div class="card-ticket-stub-section">
                                    <div style="display: flex; flex-direction: row; gap: 0.6rem; width: 100%;">
                                        <form method="POST" action="<%= `/organiser/event/${event.event_id}/publish` %>" style="margin: 0; width: 100%;">
                                            <button type="submit" class="btn btn-sm btn-primary-custom w-100">Publish</button>
                                        </form>
                                        <form method="POST" action="<%= `/organiser/event/${event.event_id}/delete` %>" style="margin: 0; width: 100%;">
                                            <button type="submit" class="btn btn-sm btn-danger-custom w-100" onclick="return confirm('Delete this draft event? This cannot be undone.')">Delete</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% } else { %>
                    <div class="empty-state">
                        <p>No draft events yet.</p>
                        <p class="text-muted small">Click "Create New Event" to start building your first event.</p>
                    </div>
                <% } %>
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <% if (flash) { %>
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                showToast('<%= flash.message %>', '<%= flash.type %>');
            });
        </script>
    <% } %>
</body>
</html>
