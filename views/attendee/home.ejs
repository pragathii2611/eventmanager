<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/main.css">
    <title>Browse Events</title>
    <script src="/main.js" defer></script>
</head>
<body>
    <nav class="navbar">
        <div class="container-fluid">
            <span class="navbar-brand">Event Manager</span>
            <a href="/" class="btn btn-secondary-custom btn-sm">Home</a>
        </div>
    </nav>

    <div class="container">
        <!-- Header -->
        <div class="section">
            <h6 class="page-kicker">Attendee Home Page</h6>
            <h1>Browse Events</h1>
            <h2><%= site_name %></h2>
            <p class="text-muted"><%= site_description %></p>
        </div>

        <!-- Events List -->
        <div class="section">
            <h3 class="section-title">Upcoming Events</h3>

            <% if (events && events.length > 0) { %>
                <div class="event-grid">
                    <% events.forEach(event => { %>
                        <div class="card-ticket-stub">
                            <a href="<%= `/attendee/event/${event.event_id}` %>" class="card-ticket-main">
                                <h4><%= event.title %></h4>
                                <p class="text-muted mb-2">
                                    <%= new Date(event.event_date).toLocaleDateString('en-GB', { weekday: 'short', month: 'short', day: 'numeric' }) %>
                                    at <%= new Date(event.event_date).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' }) %>
                                </p>
                                <div>
                                    <span class="badge-stamp published">Available</span>
                                </div>
                            </a>
                            <div class="card-ticket-stub-section">
                                <a href="<%= `/attendee/event/${event.event_id}` %>" class="btn btn-sm btn-primary-custom" style="width: 100%;">View &amp; Book</a>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <p>No events scheduled right now.</p>
                    <p class="text-muted small">Check back soon for upcoming events.</p>
                </div>
            <% } %>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <% if (flash) { %>
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                showToast('<%= flash.message %>', '<%= flash.type %>');
            });
        </script>
    <% } %>
</body>
</html>
