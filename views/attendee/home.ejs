<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/main.css">
    <title>Browse Events</title>
</head>
<body>
    <nav class="navbar">
        <div class="container-fluid">
            <span class="navbar-brand">Event Manager</span>
            <a href="/" class="btn btn-secondary btn-sm">Home</a>
        </div>
    </nav>

    <div class="container">
        <!-- Header -->
        <div class="section">
            <h1>Browse Events</h1>
            <h2><%= site_name %></h2>
            <p class="text-muted"><%= site_description %></p>
        </div>

        <!-- Events List -->
        <div class="section">
            <h3 class="section-title">Upcoming Events</h3>

            <% if (events && events.length > 0) { %>
                <div>
                    <% events.forEach(event => { %>
                        <a href="<%= `/attendee/event/${event.event_id}` %>" class="list-group-item">
                            <div class="d-flex w-100 justify-content-between align-items-center">
                                <div>
                                    <h4 class="mb-1"><%= event.title %></h4>
                                    <small class="text-muted"><%= new Date(event.event_date).toLocaleDateString('en-GB', { weekday: 'short', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></small>
                                </div>
                                <span class="badge badge-status badge-published">Available</span>
                            </div>
                        </a>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <p>No events scheduled right now.</p>
                    <p class="text-muted small">Check back soon for upcoming events.</p>
                </div>
            <% } %>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
