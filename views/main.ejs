<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/main.css">
    <title>Event Manager</title>
</head>
<body>
    <div class="container mt-5">
        <div class="row">
            <div class="col-md-8 offset-md-2">
                <h1 class="text-center mb-5">Event Manager</h1>

                <div class="row">
                    <!-- Organiser Link -->
                    <div class="col-md-6 mb-3">
                        <div class="card-custom text-center">
                            <h3 class="mb-3">Organiser</h3>
                            <p class="text-muted mb-4">Manage your events, settings, and bookings</p>
                            <a href="/organiser" class="btn btn-primary">Go to Organiser Home</a>
                        </div>
                    </div>

                    <!-- Attendee Link -->
                    <div class="col-md-6 mb-3">
                        <div class="card-custom text-center">
                            <h3 class="mb-3">Attendee</h3>
                            <p class="text-muted mb-4">Browse events and book tickets</p>
                            <a href="/attendee" class="btn btn-primary">Go to Attendee Home</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
